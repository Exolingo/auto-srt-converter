# 로컬 개발용 환경변수 파일
# 이 파일을 복사해서 .env.local 로 저장 후 값을 입력하세요
# Vercel 배포 시에는 Vercel Dashboard > Settings > Environment Variables 에서 설정

# 앱 접근 비밀번호
VITE_APP_PASSWORD=your_password_here

# OpenAI API Key (Whisper 음성 인식)
# https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Google Gemini API Key (한→영 번역)
# https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIza...
